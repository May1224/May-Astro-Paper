---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { CollectionEntry } from "astro:content";
import IconCalendar from "@/assets/icons/IconCalendar.svg";
import { getPostUrl } from "@/utils/getPostPaths";
import { getReadingTime } from "@/utils/getReadingTime";
import { slugifyStr } from "@/utils/slugify";
import { toTransitionName } from "@/utils/toTransitionName";
import { tplStr, useTranslations } from "@/i18n";
import config from "@/config";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath, body } = Astro.props;
const { title, description, tags, pubDatetime, modDatetime } = data;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const postUrl = getPostUrl(id, filePath, locale);
const displayDate = new Date(modDatetime ?? pubDatetime);
const { minutes } = getReadingTime(body ?? "");
---

<li class="border-border border-b py-6 first:pt-0 last:border-b-0">
  <article>
    <ul class="mb-2 flex flex-wrap gap-x-3 gap-y-1 text-sm">
      {
        tags.slice(0, 3).map(tag => (
          <li>
            <a
              href={getRelativeLocaleUrl(locale, `tags/${slugifyStr(tag)}/`)}
              class="text-muted-foreground hover:text-accent"
            >
              #{tag}
            </a>
          </li>
        ))
      }
    </ul>

    <a href={postUrl} class="inline-block focus-visible:no-underline">
      <Heading
        transition:name={toTransitionName(title)}
        class="hover:text-accent text-xl leading-snug font-semibold"
      >
        {title}
      </Heading>
    </a>

    <div
      class="text-muted-foreground mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm"
    >
      <span class="flex items-center gap-1.5">
        <IconCalendar class="size-4" />
        <time datetime={displayDate.toISOString()}>
          {
            new Intl.DateTimeFormat(locale, {
              year: "numeric",
              month: "short",
              day: "numeric",
            }).format(displayDate)
          }
        </time>
      </span>
      <span>{tplStr(t.post.readingTime, { minutes })}</span>
    </div>

    <p class="text-muted-foreground mt-3 leading-7">{description}</p>
  </article>
</li>
