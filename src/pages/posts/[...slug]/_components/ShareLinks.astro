---
import LinkButton from "@/components/LinkButton.astro";
import IconCopy from "@/assets/icons/IconCopy.svg";
import { tplStr, useTranslations } from "@/i18n";
import config from "@/config";

const { shareLinks } = config;
const t = useTranslations(Astro.currentLocale);

const icons = import.meta.glob<{
  default: (_props: Record<string, unknown>) => unknown;
}>("/src/assets/icons/socials/*.svg");

const pageUrl = Astro.url.href;

const platformLabel = (name: string) =>
  name.charAt(0).toUpperCase() + name.slice(1);

const items = await Promise.all(
  shareLinks.map(async ({ name, url, linkTitle }) => {
    const mod = await icons[`/src/assets/icons/socials/${name}.svg`]?.();
    const Icon = mod?.default;
    const title =
      linkTitle ??
      (name === "mail"
        ? t.post.sharePostViaEmail
        : tplStr(t.post.sharePostOn, { platform: platformLabel(name) }));
    return { url, title, Icon };
  })
);
---

{
  (
    <div class="flex flex-none flex-col items-center justify-center gap-1 md:items-start">
      <span class="italic">{t.post.sharePostIntro}</span>
      <div class="flex items-center gap-1 text-center">
        <button
          type="button"
          class="copy-link group hover:text-accent inline-flex items-center gap-2 p-2 text-sm sm:p-1"
          data-label={t.post.copyLink}
          data-copied-label={t.post.copiedLink}
          title={t.post.copyLink}
        >
          <IconCopy class="size-5" />
          <span aria-live="polite">{t.post.copyLink}</span>
        </button>
        {items.map(({ url, title, Icon }) =>
          Icon ? (
            <LinkButton
              href={`${url}${encodeURIComponent(pageUrl)}`}
              class="p-2 sm:p-1"
              title={title}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Icon class="inline-block size-6 scale-125 fill-transparent stroke-current stroke-2 opacity-90 group-hover:fill-transparent sm:scale-110" />
              <span class="sr-only">{title}</span>
            </LinkButton>
          ) : null
        )}
      </div>
    </div>
  )
}

<script>
  function initCopyLink() {
    document
      .querySelectorAll<HTMLButtonElement>(".copy-link")
      .forEach(button => {
        if (button.dataset.ready === "true") return;
        button.dataset.ready = "true";

        button.addEventListener("click", async () => {
          await navigator.clipboard.writeText(window.location.href);
          const label = button.querySelector("span");
          if (!label) return;
          label.textContent = button.dataset.copiedLabel ?? "链接已复制";
          window.setTimeout(() => {
            label.textContent = button.dataset.label ?? "复制链接";
          }, 1600);
        });
      });
  }

  initCopyLink();
  document.addEventListener("astro:after-swap", initCopyLink);
</script>
