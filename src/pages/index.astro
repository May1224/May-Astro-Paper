---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import Tag from "@/components/Tag.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getUniqueTags } from "@/utils/getUniqueTags";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { posts: postsConfig } = config;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts
  .filter(({ data }) => data.featured)
  .slice(0, 1);
const recentPosts = sortedPosts
  .filter(({ data }) => !data.featured)
  .slice(0, postsConfig.perIndex);
const popularTags = getUniqueTags(sortedPosts).slice(0, 6);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b py-10 sm:py-14">
      <!-- <p class="text-accent mb-3 text-sm font-semibold">
        前端 · 工程实践 · 成长记录
      </p> -->
      <h1 class="text-3xl font-bold sm:text-4xl">Per aspera ad astra</h1>
      <p class="text-muted-foreground mt-4 max-w-2xl leading-7">
        循此苦旅 以抵繁星
      </p>
    </section>

    {
      featuredPosts.length > 0 && (
        <section id="featured" class="border-border border-b py-10">
          <div class="mb-6 flex items-end justify-between gap-4">
            <div>
              {/* <p class="text-accent text-sm font-medium">优先推荐</p> */}
              <h2 class="mt-1 text-2xl font-semibold">{t.home.featured}</h2>
            </div>
          </div>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="border-border border-b py-10">
          <div class="mb-6 flex items-end justify-between gap-4">
            <h2 class="text-2xl font-semibold">{t.home.recentPosts}</h2>
            <LinkButton
              href={getRelativeLocaleUrl(locale, "posts")}
              class="text-sm"
            >
              {t.home.allPosts}
              <IconArrowRight class="size-4 rtl:-rotate-180" />
            </LinkButton>
          </div>
          <ul>
            {recentPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      popularTags.length > 0 && (
        <section class="py-10">
          <h2 class="mb-5 text-xl font-semibold">{t.home.browseTags}</h2>
          <ul class="flex flex-wrap gap-x-5 gap-y-3">
            {popularTags.map(({ tag, tagName }) => (
              <Tag {tag} {tagName} size="sm" />
            ))}
          </ul>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
